# Written by `pnpm exec convex dev --once`.
CONVEX_DEPLOYMENT=
PUBLIC_CONVEX_URL=
PUBLIC_CONVEX_SITE_URL=

# These are Convex deployment variables, documented here for discoverability.
# Set them with `pnpm exec convex env set NAME VALUE`; do not put real secrets
# in this file.
BETTER_AUTH_SECRET=
SITE_URL=http://localhost:5173
AUTH_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:4173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Development/test deployment only. Never configure RESET_ENVIRONMENT as
# development or test on production.
RESET_ENVIRONMENT=
DEV_RESET_TOKEN=
