		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"convex-test": "0.0.54",
		"fake-indexeddb": "6.2.5",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "4.1.10"
	},
	"dependencies": {
		"@convex-dev/better-auth": "0.12.5",
		"@convex-dev/resend": "^0.2.5",
