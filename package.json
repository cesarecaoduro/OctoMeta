		"@tiptap/pm": "3.28.0",
		"@tiptap/starter-kit": "3.28.0",
		"@univerjs/preset-sheets-core": "0.25.1",
		"@univerjs/presets": "0.25.1",
		"better-auth": "1.6.23",
		"convex": "^1.42.3",
		"convex-svelte": "^0.14.0",
		"idb": "8.0.3",
		"katex": "0.18.1"
	}
